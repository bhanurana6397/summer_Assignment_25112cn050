#include<stdio.h>
int main (){
    int n,r,s,rev=0;
    printf("enter the number");
    scanf("%d",&n);
    s=n;
    while(n>0){
        r=n%10;
        rev=rev*10+r;
        n=n/10;
    }
    if(rev==s){
        printf("the number is pallindrome\n");
    }
    else{
        printf("the number is not pallindrome\n");
    }
    return 0;
}
