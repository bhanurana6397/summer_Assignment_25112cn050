#include<stdio.h>
int main () {
    int n,i,a=0,b=1,s;
    printf("enter the term to print fibonacci series \n"); //let say n>2
    scanf("%d",&n);
    printf("The series is \n");
    printf("0,1");
    for (i=1;i<n-1;i++){
        s=a+b;
        a=b;
        b=s;
        printf(",%d",s);
    }
    printf("\n");
}
